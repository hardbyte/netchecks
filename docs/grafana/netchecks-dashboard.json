{
  "title": "Netchecks Operator",
  "uid": "netchecks-operator",
  "tags": ["netchecks", "kubernetes", "operator"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "label": "Data source",
        "regex": ""
      },
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "query": "label_values(netchecks_reconcile_total, service_name)",
        "current": { "selected": false, "text": "netchecks-operator", "value": "netchecks-operator" },
        "refresh": 1,
        "label": "Service",
        "includeAll": false,
        "multi": false,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Reconciles by result",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "stacking": { "mode": "normal", "group": "A" } }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "sum by (result) (rate(netchecks_reconcile_total{service_name=\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Reconcile errors by reason",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "sum by (reason) (rate(netchecks_reconcile_total{service_name=\"$service\",result!=\"success\"}[$__rate_interval]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Reconcile duration (p50/p95/p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(netchecks_reconcile_duration_milliseconds_bucket{service_name=\"$service\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(netchecks_reconcile_duration_milliseconds_bucket{service_name=\"$service\"}[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(netchecks_reconcile_duration_milliseconds_bucket{service_name=\"$service\"}[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "Reconciles in flight",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "netchecks_reconcile_inflight{service_name=\"$service\"}",
          "legendFormat": "in flight"
        }
      ]
    },
    {
      "id": 5,
      "title": "Assertions processed",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "stacking": { "mode": "normal", "group": "A" } }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "sum by (name) (rate(netchecks_assertions_total{service_name=\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "PolicyReport upserts",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "rate(netchecks_policy_reports_updated_total{service_name=\"$service\"}[$__rate_interval])",
          "legendFormat": "PolicyReports/sec"
        }
      ]
    },
    {
      "id": 7,
      "title": "Probe duration by type (p50/p95/p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "histogram_quantile(0.50, sum by (type, le) (rate(netchecks_probe_duration_seconds_bucket{service_name=\"$service\"}[$__rate_interval])))",
          "legendFormat": "p50 {{type}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "histogram_quantile(0.95, sum by (type, le) (rate(netchecks_probe_duration_seconds_bucket{service_name=\"$service\"}[$__rate_interval])))",
          "legendFormat": "p95 {{type}}"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "histogram_quantile(0.99, sum by (type, le) (rate(netchecks_probe_duration_seconds_bucket{service_name=\"$service\"}[$__rate_interval])))",
          "legendFormat": "p99 {{type}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Reconcile success rate (1h)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 34 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          },
          "decimals": 3
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "sum(rate(netchecks_reconcile_total{service_name=\"$service\",result=\"success\"}[1h])) / clamp_min(sum(rate(netchecks_reconcile_total{service_name=\"$service\"}[1h])), 1e-9)",
          "instant": true
        }
      ]
    },
    {
      "id": 9,
      "title": "Probe p95 (1h, all types)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 34 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          },
          "decimals": 2
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(netchecks_probe_duration_seconds_bucket{service_name=\"$service\"}[1h])))",
          "instant": true
        }
      ]
    },
    {
      "id": 10,
      "title": "Reconciles in flight (now)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 34 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "netchecks_reconcile_inflight{service_name=\"$service\"}",
          "instant": true
        }
      ]
    },
    {
      "id": 11,
      "title": "Assertions tracked",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 34 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "count(count by (name) (netchecks_assertions_total{service_name=\"$service\"}))",
          "instant": true
        }
      ]
    }
  ]
}
